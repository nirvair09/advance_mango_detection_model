        "ROBOFLOW_API_KEY = os.getenv(\"ROBOFLOW_API_KEY\", \"Lkq2ojJa2S9mNjGNuviJ\")\n",
        "WORKSPACE_NAME = \"pigrecipe\"\n",
        "PROJECT_NAME = \"mango-7l7ug-napwv-razzf\"\n",
