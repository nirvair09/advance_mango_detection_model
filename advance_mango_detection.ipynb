    {
      "cell_type": "markdown",
      "metadata": {
        "id": "CFCRehIXKRE_"
      },
      "source": [
        "## 8. Crop Detected Mangoes for Ripeness Classification\n",
        "\n",
        "The detector output is reused to build a crop set that can later be classified by ripeness. Using the shared helper functions keeps crop generation consistent with inference.\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "OOpw8UcnKRE_",
        "outputId": "042be985-5f3a-4d59-c313-2248d2cfc167",
        "colab": {
          "base_uri": "https://localhost:8080/"
        }
      },
      "execution_count": 12,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Saved 1254 mango crops to /content/mango_crops\n"
          ]
        }
      ],
      "source": [
        "# Create a directory to store detected mango crops.\n",
        "CROP_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "crop_count = 0\n",
        "train_image_paths = sorted((DATASET_DIR / \"train\" / \"images\").glob(\"*\"))\n",
        "\n",
        "for image_path in train_image_paths:\n",
        "    image_array = cv2.imread(str(image_path))\n",
        "    if image_array is None:\n",
        "        continue\n",
        "\n",
        "    boxes = detect_mangoes(detector, image_array, conf_thresh=DETECTION_CONF_THRESH)\n",
        "\n",
        "    for box in boxes:\n",
        "        crop = crop_mango(image_array, box, margin=CROP_MARGIN)\n",
        "\n",
        "        # Skip invalid or empty crops to avoid write errors.\n",
        "        if crop.size == 0:\n",
        "            continue\n",
        "\n",
        "        crop_path = CROP_OUTPUT_DIR / f\"mango_{crop_count}.jpg\"\n",
        "        cv2.imwrite(str(crop_path), crop)\n",
        "        crop_count += 1\n",
        "\n",
        "print(f\"Saved {crop_count} mango crops to {CROP_OUTPUT_DIR}\")\n"
      ]
    },
